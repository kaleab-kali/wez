# ===========================================
# wez Production Environment
# ===========================================
# Render Blueprint sets these through render.yaml.
# For VPS/PM2, copy to .env and fill real values.
# ===========================================

NODE_ENV=production

# --- Database ---
DATABASE_URL=postgresql://wez:STRONG_PASSWORD_HERE@localhost:5432/wez

# --- Redis / Render Key Value ---
REDIS_URL=redis://localhost:6379

# --- Better Auth ---
BETTER_AUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32
ADMIN_AUTH_SECRET=GENERATE_A_DIFFERENT_SECRET_WITH_openssl_rand_base64_32
BETTER_AUTH_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# --- API ---
API_PORT=3005
API_HOST=0.0.0.0

# --- Full-stack serving ---
SERVE_WEB_APP=true
FRONTEND_DIST_DIR=apps/web/dist

# --- Upload storage ---
# Render free demo: this is ephemeral and may reset on restart/redeploy.
# VPS/paid Render: point this at persistent app data storage.
STORAGE_ROOT=/tmp/wez/uploads

# --- Notifications ---
# Keep disabled for demo until provider credentials are ready.
SMS_PROVIDER=disabled
EMAIL_PROVIDER=disabled

# --- Logging ---
LOG_LEVEL=info
SLOW_QUERY_THRESHOLD_MS=300

# --- Demo seed only ---
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=SET_A_STRONG_DEMO_PASSWORD
SUPER_ADMIN_NAME=Wez Demo Admin
