# ===========================================
# wez Production Environment
# ===========================================
# Copy to .env on your VPS. Fill in real values.
# ===========================================

NODE_ENV=production

# --- Database ---
DATABASE_URL=postgresql://wez:STRONG_PASSWORD_HERE@localhost:5432/wez

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Better Auth ---
BETTER_AUTH_SECRET=GENERATE_WITH_openssl_rand_base64_32
BETTER_AUTH_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# --- API ---
API_PORT=3005
API_HOST=127.0.0.1

# --- Domain ---
DOMAIN=your-domain.com
