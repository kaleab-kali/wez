NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://wez:wez@localhost:5432/wez

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Better Auth ---
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
ADMIN_AUTH_SECRET=change-me-generate-a-different-secret
BETTER_AUTH_URL=http://localhost:3005
FRONTEND_URL=http://localhost:5180

# --- API ---
API_PORT=3005
API_HOST=0.0.0.0

# --- Logging ---
LOG_LEVEL=debug
SLOW_QUERY_THRESHOLD_MS=200

# --- Static web + uploaded files ---
SERVE_WEB_APP=false
# FRONTEND_DIST_DIR=../web/dist
STORAGE_ROOT=uploads

# --- Notification providers ---
SMS_PROVIDER=disabled
EMAIL_PROVIDER=disabled

# --- Super Admin (seed) ---
SUPER_ADMIN_EMAIL=admin@novektech.com
SUPER_ADMIN_PASSWORD=SuperAdmin123!
SUPER_ADMIN_NAME=Novek Admin
# Set after running seed — contains the superadmin user ID
# SUPER_ADMIN_USER_IDS=user_id_here

# --- Telegram Alerts (optional) ---
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
