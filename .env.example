# ===========================================
# wez — All Environment Variables Reference
# ===========================================
# This file is DOCUMENTATION ONLY. It is NOT loaded by any app.
# Actual env files live in each app folder:
#   - apps/api/.env  (NestJS backend)
#   - apps/web/.env  (Vite frontend)
# Copy the relevant .env.example in each app folder.
# ===========================================

# ===================== API (apps/api/.env) =====================

NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://wez:wez@localhost:5432/wez_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Better Auth ---
BETTER_AUTH_SECRET=19f3ad2a15d00367862b157e65d19845810e3edf7b8cb8031d276bfa1f15f5bb
BETTER_AUTH_URL=http://localhost:3005
FRONTEND_URL=http://localhost:5180

# --- Super Admin (seed) ---
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=quA9X!vKUYYC#TAbbMk8
SUPER_ADMIN_NAME=Platform Admin

# --- API ---
API_PORT=3005
API_HOST=0.0.0.0

# --- Logging ---
LOG_LEVEL=debug
# LOG_LEVEL=info  # Use in production
SLOW_QUERY_THRESHOLD_MS=200

# --- Stripe (billing — fill when ready) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Telegram Alerts (optional, production) ---
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# --- Production Only ---
# DOMAIN=localhost
# BETTER_AUTH_URL=https://localhost
# FRONTEND_URL=https://localhost

# ===================== WEB (apps/web/.env) =====================

VITE_API_URL=http://localhost:3005
VITE_APP_NAME=wez
